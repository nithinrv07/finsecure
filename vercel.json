{
  "version": 2,
  "routes": [
    { "src": "/_/backend/(.*)", "dest": "/backend/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
